---
import './header.scss';

import AppButton from '@components/ui/button/button.vue';
---

<header class="header">

  <div class="container">

    <div class="header__wrapper">

      <!-- LOGO -->

      <a
        href="/"
        class="header__logo"
      >
        РЕМКОНСОЛЬ<span>.РФ</span>
      </a>

      <!-- ACTION -->

      <div class="header__action">

        <AppButton
          client:load
          text="оставить заявку"
        />

      </div>

    </div>

  </div>

</header>